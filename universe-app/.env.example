# ────────────────────────────────────────────────────────────────
# UniVerse Frontend — Environment Variables (Vite)
# Copy this file to .env and fill in your values.
# All variables MUST start with VITE_ to be exposed to the browser.
# ────────────────────────────────────────────────────────────────

# URL of your deployed backend API (no trailing slash)
# Leave empty (or omit) when using the Vite dev proxy (localhost)
VITE_API_URL=https://your-backend.railway.app
