# Copy these into your Railway service's Variables tab
# (Railway provides DATABASE_URL automatically when you add a Postgres plugin)

NODE_ENV=production
PORT=5000

# Railway auto-fills this when you add the PostgreSQL plugin:
# DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Set this to your Railway frontend URL after deploying:
CLIENT_URL=https://your-app.railway.app

# Push Notifications (keep your existing VAPID keys or generate new ones)
VAPID_PUBLIC_KEY=BIfl1t5JL8ivj-ysi7vGLqfynL6rejNkB1PLGgXDNBxjGXKdn2hUrhsecaX9OXJB42rcsa5KUU-xFzoy8WqySeA
VAPID_PRIVATE_KEY=dsOL-02AVJBtczaIoCW4Y0oiuUwvpSjbGTsmCQvMRy8
VAPID_EMAIL=mailto:admin@universe.app

# Email (optional — leave blank to disable email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Universe App <noreply@universe.app>

# Groq cloud AI (recommended for production — Ollama won't run on Railway)
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local only — leave blank on Railway)
OLLAMA_URL=
OLLAMA_MODEL=llama3.1:latest
OLLAMA_EMBED=nomic-embed-text
