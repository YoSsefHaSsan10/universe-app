# ────────────────────────────────────────────────────────────────
# UniVerse Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (PostgreSQL) ────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=universe_db
DB_USER=postgres
DB_PASSWORD=your_database_password

# ── Authentication ───────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────
# URL of your deployed frontend (or http://localhost:5173 for dev)
CLIENT_URL=https://your-app.vercel.app

# ── Push Notifications (Web Push / VAPID) ────────────────────────
# Generate once: node -e "require('web-push').generateVAPIDKeys().then(k=>console.log(k))"
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@yourdomain.com

# ── Email (SMTP) ─────────────────────────────────────────────────
# Leave SMTP_USER empty to disable email (push-only mode will be used)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Universe App <noreply@yourdomain.com>

# ── AI / LLM ─────────────────────────────────────────────────────
# Engine priority: Ollama (local) -> Groq (cloud) -> rule-based fallback

# GROQ — recommended for deployment, free tier at console.groq.com
# Sign up, create API key, paste below
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OLLAMA — local development only, not needed in production
# Install: https://ollama.com
# Then run: ollama pull nomic-embed-text
#           ollama create universe-ai -f UniVerseAI.Modelfile
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=universe-ai
OLLAMA_EMBED=nomic-embed-text
